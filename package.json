{
  "name": "codex-desktop-todo",
  "version": "0.1.0",
  "description": "一个极简的 Windows 桌面清单便签。",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run --globals",
    "build": "electron-builder --win portable"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "local.desktop.todo",
    "productName": "桌面 TODO",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "artifactName": "DesktopTODO-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "vitest": "^4.1.9"
  }
}
